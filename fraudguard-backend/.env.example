# Database & Redis Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fraudguard
REDIS_URL=redis://localhost:6379/0

# App Settings
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=http://localhost:9000,http://localhost:8080

# Security (JWT configuration)
SECRET_KEY=super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Fraud ML Model Parameters
FRAUD_THRESHOLD_AMOUNT=10000.0
FRAUD_THRESHOLD_SCORE=80
RISK_MULTIPLIER=1.5
MAX_TRANSACTION_LIMIT=100000.0
REQUIRE_2FA_OVER=50000.0

# Third-Party / SMTP Integrations
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@gmail.com
SMTP_PASSWORD=pass
